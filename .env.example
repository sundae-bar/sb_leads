# Supabase (local dev — from `supabase status`)
SUPABASE_URL=http://localhost:54331
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# API
API_URL=http://localhost:4000
API_PORT=4000
WEB_URL=http://localhost:3002

# Next.js public vars (prefix with NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54331
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:4000

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Trigger.dev (optional)
TRIGGER_SECRET_KEY=your-trigger-secret-key
TRIGGER_API_URL=https://api.trigger.dev

# Stripe (test-mode keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_...
# Get this from `stripe listen --forward-to localhost:3002/api/billing/webhook`
STRIPE_WEBHOOK_SECRET=whsec_...
# Recurring price IDs created in Stripe Dashboard. Must match plan keys in
# packages/types/src/billing.ts.
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...

# Optional: tenant_id used by Trigger.dev cron jobs to record traces.
SYSTEM_TENANT_ID=

# API key security
# Generate API_KEY_ENCRYPTION_KEY: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
API_KEY_ENCRYPTION_KEY=your-base64-32-byte-key
# Random string used to pepper API key hashes (any long random string works)
API_KEY_PEPPER=your-random-pepper-string
# Used to AES-GCM-encrypt raw values of *managed* api_keys (e.g. the chat
# agent's own MCP key). Generate with: openssl rand -hex 32
MANAGED_KEY_SECRET=your-random-managed-key-secret-32-bytes

# the402.ai marketplace listing (https://the402.ai/docs/providers/).
# Leave blank to skip the integration locally.
THE402_API_URL=https://api.the402.ai
THE402_API_KEY=
THE402_WEBHOOK_SECRET=

# x402 direct payment endpoint (POST /x402/find-email). Defaults are Base
# Sepolia testnet + free public facilitator. Set X402_PAY_TO_ADDRESS to any
# testnet wallet; for mainnet, swap URLs and set CDP_* credentials.
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK=eip155:84532
X402_PAY_TO_ADDRESS=
X402_FIND_EMAIL_PRICE=$0.25
X402_DISCOVERABLE=false
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Leads provider API keys
LOG_LEVEL=info
ALEADS_API_KEY=
APOLLO_API_KEY=
NYMERIA_API_KEY=
CONTACTOUT_API_KEY=
HUNTERIO_API_KEY=
