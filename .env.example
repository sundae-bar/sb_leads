# Scoop — env reference. `cp .env.example .env`, fill SUPABASE_* from
# `supabase status -o env`. One root .env feeds web + api + scripts locally.
# On Railway, set these per service (web vs api) — no .env file is shipped.

# ── Supabase (from `supabase status -o env`) ────────────────────────────────
SUPABASE_URL=http://localhost:54331
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Not read by app code; kept for parity with `supabase status`.
SUPABASE_JWT_SECRET=your-jwt-secret

# Next.js public vars (browser-exposed; same Supabase values)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54331
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── App wiring ──────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
API_URL=http://localhost:4000
API_PORT=4000
WEB_URL=http://localhost:3004
# Reverse-proxy hops in front of the API (Railway edge = 1; Cloudflare-proxied
# custom domain in front = 2). Drives req.ip for rate limiting — keep exact.
TRUST_PROXY_HOPS=1
# Web auth provider; clerk is a stub. Set the CLERK vars only if using it.
AUTH_PROVIDER=supabase
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# ── OpenAI (chat agent) ─────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key

# ── Trigger.dev (optional; cron runs only when key is set) ──────────────────
TRIGGER_SECRET_KEY=
TRIGGER_API_URL=https://api.trigger.dev

# ── Stripe (test-mode keys; webhook secret is web-only) ─────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Legacy plan price IDs (grandfathered subs only; blank for credit-pack plans).
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_GROWTH_ANNUAL=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_BUSINESS_ANNUAL=

# tenant_id used by Trigger.dev cron to record traces.
SYSTEM_TENANT_ID=

# ── API-key security ────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
API_KEY_ENCRYPTION_KEY=your-base64-32-byte-key
API_KEY_PEPPER=your-random-pepper-string
# AES-GCM secret for managed api_keys. Generate: openssl rand -hex 32
MANAGED_KEY_SECRET=your-random-managed-key-secret-32-bytes

# ── Lead-sourcing providers (empty key = provider skipped) ──────────────────
ALEADS_API_KEY=
APOLLO_API_KEY=
NYMERIA_API_KEY=
CONTACTOUT_API_KEY=
HUNTERIO_API_KEY=
# Stub providers (not implemented) — leave blank:
PEOPLEDATALABS_API_KEY=
SNOV_API_KEY=
LUSHA_API_KEY=
ROCKETREACH_API_KEY=
ZOOMINFO_API_KEY=

# ── the402.ai marketplace (blank keys = integration off) ────────────────────
THE402_API_URL=https://api.the402.ai
THE402_API_KEY=
THE402_WEBHOOK_SECRET=
THE402_CALLBACK_HOSTS=

# ── x402 endpoint (defaults = Base Sepolia testnet) ─────────────────────────
# For mainnet: set X402_NETWORK=eip155:8453, swap facilitator, set CDP_* creds.
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK=eip155:84532
X402_PAY_TO_ADDRESS=
X402_FIND_EMAIL_PRICE=$0.25
X402_DISCOVERABLE=false
# Deadline (ms) for the provider fan-out on the paid endpoint. On expiry the
# buyer is not charged (504 → payment cancelled). Keep below the client timeout.
X402_FIND_EMAIL_TIMEOUT_MS=20000
X402_RESOURCE_URL=
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# ── Local scripts only (apps/api/scripts/*) — never deployed ────────────────
CDP_WALLET_SECRET=
X402_BUYER_PRIVATE_KEY=
X402_TEST_ENDPOINT=
X402_TEST_LINKEDIN=
X402_MAINNET_ENDPOINT=
