{
  "name": "@scoop/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "pnpm --filter @scoop/types build && tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --dir __tests__",
    "the402:sync": "tsx --env-file=../../.env scripts/sync-the402-services.ts",
    "cdp:create-eoa": "tsx --env-file=../../.env scripts/create-cdp-eoa.ts",
    "x402:self-test": "tsx --env-file=../../.env scripts/x402-self-test.ts",
    "discovery:poll": "tsx --env-file=../../.env scripts/poll-discovery.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.106",
    "@coinbase/x402": "^2.1.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@scoop/types": "workspace:*",
    "@supabase/supabase-js": "^2.43.0",
    "@trigger.dev/sdk": "^3.0.0",
    "@x402/core": "^2.12.0",
    "@x402/evm": "^2.12.0",
    "@x402/express": "^2.12.0",
    "ai": "^5.0.186",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^5.0.0",
    "jsonwebtoken": "^9.0.0",
    "lru-cache": "^10.4.3",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "stripe": "^17.0.0",
    "undici": "^6.21.0",
    "ws": "^8.20.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@coinbase/cdp-sdk": "^1.49.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "@x402/fetch": "^2.12.0",
    "supertest": "^7.2.2",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "viem": "^2.49.0",
    "vitest": "^2.1.0"
  }
}
