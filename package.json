{
  "name": "sundae",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "create-user": "tsx --env-file=.env scripts/create-user.ts",
    "create-admin": "tsx --env-file=.env scripts/create-admin.ts",
    "backfill-active-tenant": "tsx --env-file=.env scripts/backfill-active-tenant.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.43.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
